{
  "name": "slides-md",
  "version": "1.0.0",
  "description": "PowerPoint Markdown Add-in with LaTeX math support",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack serve --mode development",
    "start": "webpack serve --mode development",
    "install-certs": "npx office-addin-dev-certs install",
    "sideload": "npx office-toolbox sideload -m manifest.xml -a powerpoint",
    "test": "jest"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.1",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.15",
    "html2canvas": "^1.4.1",
    "katex": "^0.16.11",
    "markdown-it": "^14.1.0",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "markdown-it-texmath": "^1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/office-js": "^1.0.421",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^30.2.0",
    "office-addin-dev-certs": "^2.0.6",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
